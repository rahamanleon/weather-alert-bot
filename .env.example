# Weather API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here
WEATHERAPI_API_KEY=your_weatherapi_key_here

# MongoDB (optional - for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/weather-alert-bot

# App Configuration
PORT=3000
LOG_LEVEL=info
TIMEZONE=UTC

# WhatsApp Configuration
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_RATE_LIMIT_MS=1000

# Alert Configuration
DEFAULT_RAIN_THRESHOLD_PCT=60
DEFAULT_EARLY_COOLDOWN_MINUTES=120
DEFAULT_FINAL_COOLDOWN_MINUTES=60

# Cache Configuration
FORECAST_TTL_MINUTES=15
CACHE_MAX_ENTRIES=100

# Scheduler
SCHEDULER_INTERVAL_MINUTES=10
{
  "app": {
    "port": 3000,
    "logLevel": "info",
    "timezone": "UTC",
    "schedulerIntervalMinutes": 10
  },
  "apis": {
    "openWeather": {
      "apiKey": "YOUR_OPENWEATHER_API_KEY_HERE",
      "enabled": true
    },
    "weatherApi": {
      "apiKey": "YOUR_WEATHERAPI_KEY_HERE",
      "enabled": true
    },
    "openMeteo": {
      "enabled": true
    }
  },
  "whatsapp": {
    "sessionPath": "./sessions",
    "messageRateLimitMs": 1000
  },
  "alerts": {
    "defaultRainThresholdPct": 60,
    "defaultEarlyCooldownMinutes": 120,
    "defaultFinalCooldownMinutes": 60
  },
  "cache": {
    "forecastTtlMinutes": 15,
    "maxEntries": 100
  },
  "database": {
    "mongoUri": "mongodb+srv://username:password@cluster.mongodb.net/weather-alert-bot",
    "useInMemoryFallback": true
  },
  "users": [
    {
      "id": "user_001",
      "whatsappNumber": "+60123456789",
      "location": {
        "lat": 3.139,
        "lon": 101.6869,
        "city": "Kuala Lumpur",
        "country": "MY"
      },
      "rainThresholdPct": 65,
      "earlyCooldownMinutes": 120,
      "finalCooldownMinutes": 60,
      "active": true
    }
  ]
}